# OpsRunbook Copilot – API service environment variables
# Copy to services/api/.env and fill in your values. NEVER commit .env itself.
#
# Generate a random API key:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── API Authentication ────────────────────────────────────────────
API_KEY=<generate with: python -c "import secrets; print(secrets.token_urlsafe(32))">

# ── AWS ───────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Storage (from Terraform outputs) ─────────────────────────────
EVIDENCE_BUCKET=<terraform output: evidence_bucket>
INCIDENTS_TABLE=<terraform output: incidents_table>
SNAPSHOTS_TABLE=<terraform output: snapshots_table>
PACKETS_TABLE=<terraform output: packets_table>

# ── Orchestrator ──────────────────────────────────────────────────
STATE_MACHINE_ARN=<terraform output: state_machine_arn>
EVENT_BUS_NAME=<terraform output: event_bus_name>

# ── Budgets ───────────────────────────────────────────────────────
MAX_ROWS_PER_QUERY=100
MAX_BYTES_TOTAL=200000
MAX_TIME_WINDOW_MINUTES=15

# ── Iteration 6: GitHub webhooks / PR review cycle ────────────────
GITHUB_WEBHOOK_SECRET=<set in AWS SSM: /opsrunbook/dev/github/webhook_secret>
GITHUB_APP_SLUG=<your-github-app-slug>
PR_REVIEW_STATE_MACHINE_ARN=<terraform output: pr_review_state_machine_arn>

# ── Replay harness (local dev only) ──────────────────────────────
# Absolute path to actions_runner/src so the replay endpoint can
# import plan_generator without it being installed as a package.
PLAN_GENERATOR_PATH=<absolute-path-to-repo>/infra/terraform/modules/actions_runner/src
